# Database (PostgreSQL - use Neon, Supabase, or other provider)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Authentication (Better Auth)
BETTER_AUTH_SECRET=generate-a-secure-random-string-min-32-chars
BETTER_AUTH_URL=https://www.your-domain.com
# Comma-separated list of trusted origins. Must include BOTH www.colist.fr
# and sortie.colist.fr in production to support cross-subdomain sessions.
BETTER_AUTH_TRUSTED_ORIGINS=https://www.your-domain.com,https://sortie.your-domain.com

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Features (Vercel AI Gateway Quickstart)
AI_GATEWAY_API_KEY=vck_your_virtual_key_here

# Google AI Studio (Gemini direct, free tier with grounded search up to 1500 req/day)
# Create at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ============================================================================
# Sortie (sortie.colist.fr) — optional for dev, required for production.
# ============================================================================

# Public base URL of Sortie. Used for building absolute links in emails and
# Open Graph metadata. No trailing slash.
SORTIE_BASE_URL=https://sortie.your-domain.com

# Shared secret for Vercel Cron endpoints under /api/cron/sortie/*.
# Generate with: openssl rand -hex 32
# Must be set as Authorization: Bearer ${CRON_SECRET} in vercel.json crons.
CRON_SECRET=generate-32-bytes-hex

# IBAN / payment-method encryption keys (AES-256-GCM). Base64-encoded 32-byte
# keys, one per rotation. SORTIE_IBAN_KEY_ID_ACTIVE selects which key is used
# for new writes; older keys remain set so existing rows can still be decrypted.
# Generate each with: openssl rand -base64 32
SORTIE_IBAN_KEY_ID_ACTIVE=k1
SORTIE_IBAN_KEY_K1=base64-encoded-32-bytes
# SORTIE_IBAN_KEY_K2=  # uncomment when rotating

# Ticketmaster Discovery API consumer key. Optional — when unset, the
# best-effort title-search enrichment in the create wizard is silently
# disabled (no error to the user). Get a key at developer.ticketmaster.com.
TICKETMASTER_API_KEY=

# OpenAgenda public API key. Optional — complète Ticketmaster avec les
# événements culturels/locaux français (mairies, festivals, médiathèques)
# que TM ne référence pas. Crée un compte sur openagenda.com puis copie
# la clé publique depuis les paramètres du compte.
OPENAGENDA_API_KEY=


